{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Size Scanner",
  "version": "1.0.2",
  "identifier": "com.eerie.sizescanner",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Size Scanner",
        "width": 980,
        "height": 640,
        "minWidth": 760,
        "minHeight": 460,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "EERIE",
    "copyright": "© 2026 EERIE",
    "category": "Utility",
    "shortDescription": "Find the largest files and folders on your PC",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
